#!/usr/bin/env bash
set -euo pipefail

# Runs the exact gate suite that CI runs. If any step fails the push is aborted.
# To install: `git config core.hooksPath .githooks && chmod +x .githooks/pre-push`

echo "[1/5] cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

echo "[2/5] cargo test"
cargo test

echo "[3/5] python3 -m ruff check scripts/ tests/ --select E,F,W,I --ignore E501"
python3 -m ruff check scripts/ tests/ --select E,F,W,I --ignore E501

echo "[4/5] cargo run --quiet --release -- validate"
cargo run --quiet --release -- validate

echo "[5/5] python3 -m pytest -q"
python3 -m pytest -q

echo "All gates passed. Pushing."
