#!/usr/bin/env bash
set -euo pipefail

# Runs the exact gate suite that CI runs. If any step fails the push is aborted.
# To install: `git config core.hooksPath .githooks && chmod +x .githooks/pre-push`

echo "[1/6] cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

echo "[2/6] cargo test"
cargo test

echo "[3/6] python3 -m ruff check scripts/ tests/ --select E,F,W,I --ignore E501"
python3 -m ruff check scripts/ tests/ --select E,F,W,I --ignore E501

echo "[4/6] python3 -m ruff format --check scripts/ tests/"
python3 -m ruff format --check scripts/ tests/

echo "[5/6] cargo run --quiet --release -- validate"
cargo run --quiet --release -- validate

echo "[6/6] python3 -m pytest -q"
python3 -m pytest -q

echo "All gates passed. Pushing."
