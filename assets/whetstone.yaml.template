# Whetstone Configuration
# Generated by: whetstone init
# Documentation: https://github.com/whetstone/whetstone
#
# Precedence (later wins):
#   built-in defaults < ~/.whetstone/config.yaml (global)
#     < whetstone/whetstone.yaml (project, this file)
#     < whetstone/.personal/config.yaml (gitignored, personal)
# Run `wh config show` to print the effective config with per-key provenance.

# Languages detected in this project
languages:
  - python
  # - typescript
  # - rust

# Trigger mode: when Whetstone checks for updates
trigger:
  mode: manual          # manual | session | post-merge | scheduled
  # schedule: weekly    # Only for scheduled mode: daily | weekly | biweekly | monthly
  auto_detect_patterns: true  # Run detect-patterns on session start (session mode)

# Agent context files to generate
# Each entry generates a file at the project root (or specified location)
agents:
  - claude.md              # → CLAUDE.md
  - agents.md              # → AGENTS.md
  # - cursorrules          # → .cursorrules
  # - copilot-instructions.md  # → .github/copilot-instructions.md
  # - windsurfrules        # → .windsurfrules
  # - codex.md             # → codex.md

# Discovery settings: control which directories are scanned for manifests
# discovery:
#   exclude:                    # Additional directories to skip during manifest search
#     - "tests/fixtures"
#     - "examples"
#     - "vendor"
#   include: []                 # Directories to include even if normally skipped

# Source overrides (optional)
# Add custom documentation sources beyond auto-detected dependencies
# sources:
#   custom:
#     - url: https://team-style-guide.example.com
#       name: Team Style Guide
#     - url: https://blog.example.com/best-practices
#       name: Best Practices Blog

# Extraction controls (3D.2.1)
# Tailor which deps get rules, and what shape those rules must take.
# extraction:
#   include: []                    # dep allowlist (empty = no filter)
#   exclude:                       # deps to skip entirely
#     - pytest                     # dev-only, rarely produces good rules
#   max_rules_per_dep: 5           # schema cap: at most 5 rules per dep
#   allowed_categories:            # empty = all five allowed
#     - migration
#     - default
#     - convention
#     - breaking-change
#     - semantic
#   min_confidence: medium         # high | medium (default: medium accepts both)
#   preferred_source_kinds:        # ranking input for the extraction worklist
#     - changelog
#     - migration_guide
#     - official_docs
#   recency_window_days: 540       # boost sources published within this window

# Resolve pipeline defaults (3D.2.2)
# resolve:
#   cache_ttl_seconds: 604800      # 7 days
#   timeout_seconds: 15            # HTTP request timeout
#   workers: 4                     # parallel resolution workers

# `wh check` defaults (3D.2.2) — gates on rule violations found in source files.
# `wh ci --fail-on` is unrelated (it gates on freshness, not violations).
# check:
#   paths:                         # scan paths when none supplied on the CLI
#     - src/
#   fail_on: both                  # violations | config_issues | both | none

# `wh bench` defaults (3D.2.2)
# bench:
#   min_f1: 0.9                    # minimum F1 per scenario for `--check`
#   corpus_dir: benchmarks         # override the default corpus location

# Pattern detection settings
# patterns:
#   min_occurrences: 3     # Minimum times a pattern must appear (default: 2)
#   sources:               # Which sources to mine (default: all)
#     - transcript
#     - git
#     - pr

