# Whetstone Configuration Template
#
# Copy the sections you need into:
#   - whetstone/whetstone.yaml        (project, committed)
#   - ~/.whetstone/config.yaml        (global defaults)
#   - whetstone/.personal/config.yaml (personal overrides, gitignored)
#
# Effective precedence:
#   built-in defaults < global < project < personal
#
# Inspect the merged result with:
#   wh config show --project-dir .
# Validate keys + values with:
#   wh config validate --project-dir .

# Discovery filters
# discovery:
#   exclude:
#     - tests/fixtures
#   include: []

# Generated context formats
# generate:
#   formats:
#     - agents.md
#     - claude.md
#     # - .cursorrules
#     # - copilot-instructions.md
#     # - .windsurfrules
#     # - codex.md

# Extra documentation sources
# sources:
#   custom:
#     - url: https://team-style-guide.example.com
#       name: team-style-guide
#       language: generic
#       source_kind: style_guide

# Rule ids to suppress from merged output
# deny:
#   - rust.expect-over-unwrap

# Extraction controls
# extraction:
#   include: []                    # dep allowlist (empty = no filter)
#   exclude: []                    # deps to skip entirely
#   max_rules_per_dep: 5           # must stay within 1..=5
#   allowed_categories:
#     - migration
#     - default
#     - convention
#     - breaking-change
#     - semantic
#   min_confidence: medium         # high | medium
#   preferred_source_kinds:
#     - changelog
#     - migration_guide
#     - official_docs
#   recency_window_days: 540

# Resolve defaults
# resolve:
#   cache_ttl_seconds: 604800      # > 0
#   timeout_seconds: 15            # > 0
#   workers: 4                     # > 0

# `wh check` defaults
# check:
#   paths:
#     - src/
#   fail_on: both                  # violations | config_issues | both | none

# Global-only keys (only valid in ~/.whetstone/config.yaml)
# default_formats:
#   - agents.md
# default_languages:
#   - python
