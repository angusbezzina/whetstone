flowchart TD
    %% ═══════════════════════════════════════════════════════════════════
    %% WHETSTONE — logic flow
    %% Last updated: 2026-04-21  (state of `main` with [Unreleased] → 0.4.0)
    %%
    %% Legend:
    %%   Amber  = entry point
    %%   Green  = Binary  (shipped deterministic commands)
    %%   Orange = Agent   (judgment via SKILL.md)
    %%   Blue   = User    (approval / preference decisions)
    %%   Purple = Authoring shortcut / source subscription / JIT lookup
    %%   Grey   = Deferred / future
    %% ═══════════════════════════════════════════════════════════════════

    START([User: run whetstone])

    %% ─── Source subscriptions (optional, before bootstrap) ──────────────
    SOURCE_ADD["wh source add &lt;url&gt;<br/>--name / --lang / --kind<br/>--personal (default) | --project"]
    SOURCE_OPS["wh source list<br/>wh source fetch &lt;name&gt;<br/>wh source remove &lt;target&gt;"]
    START -.->|subscribe a blog / wiki /<br/>llms.txt / internal doc| SOURCE_ADD
    SOURCE_ADD --> INIT
    SOURCE_OPS -.-> INIT

    %% ─── Personal-taste authoring shortcut (bypasses extract/submit/approve) ──
    AUTHOR_SHORT["wh rule add &lt;id&gt;<br/>--description / --match / --lang<br/>Writes .personal/rules/ as APPROVED"]
    START -.->|I already know the rule| AUTHOR_SHORT
    AUTHOR_SHORT --> ACTIONS

    %% ─── Primary loop: bootstrap → extract → approve → generate → verify → monitor → maintain ──
    START --> INIT["wh init<br/>Detect manifests<br/>Resolve dep docs + changelogs<br/>Fetch subscribed sources<br/>Write extraction-handoff.json"]

    INIT --> EXTRACT["wh extract<br/>Walk worklist<br/>Next dep or custom source<br/>Ranked sections + quota"]
    EXTRACT --> AGENT_EXTRACT["Agent reads the handoff<br/>Reads the dep's docs<br/>Drafts a candidate bundle YAML"]
    AGENT_EXTRACT --> SUBMIT["wh extract submit &lt;bundle.yaml&gt;<br/>Validate ids, write status: candidate<br/>whetstone/rules/&lt;lang&gt;/&lt;dep&gt;.yaml"]

    SUBMIT --> USER{"User reviews<br/>candidate set"}
    USER -->|wh approve --all<br/>or wh approve &lt;id&gt;| APPROVE["wh approve<br/>candidate → approved<br/>Single id or batch filter"]
    USER -->|edit and resubmit| AGENT_EDIT["Agent edits bundle"]
    AGENT_EDIT --> SUBMIT
    USER -.->|already approved —<br/>bump severity| RULE_EDIT["wh rule edit &lt;id&gt; --severity must<br/>or --all --dep X --category Y<br/>--dry-run supported"]
    RULE_EDIT --> APPROVE

    APPROVE --> VALIDATE["wh validate<br/>Schema + fixture checks"]
    VALIDATE -->|fix issues| AGENT_FIX["Agent fixes YAML"]
    AGENT_FIX --> VALIDATE
    VALIDATE --> ACTIONS["wh actions [--terse]<br/>wh context → AGENTS.md + AGENTS.&lt;lang&gt;.md sidecars<br/>wh tests   → pytest / vitest / cargo test<br/>wh lint    → ruff / biome / clippy overlays"]

    ACTIONS --> CHECK["wh check src/<br/>Tree-sitter AST queries<br/>AST-scoped regex<br/>lint_proxy verification"]
    CHECK --> STATUS["wh status<br/>rule_system_score + adherence_score<br/>Violation trend in .metrics.jsonl"]
    STATUS --> REPORT["wh report [--pr-comment] [--json]<br/>One-page markdown narrative<br/>Top 10 violations + next actions"]
    REPORT --> DONE([Done: rules enforced, agents informed, repo scored])

    %% ─── JIT side-channel (any time — especially during AGENT_EXTRACT) ──
    RULES_QUERY["wh rules query --file &lt;path&gt;<br/>Filters: --lang / --dep / --severity / --full<br/>JSON envelope: { total, filters, rules[] }"]
    AGENT_EXTRACT -.->|what rules apply here?| RULES_QUERY
    RULES_QUERY -.->|filtered rule set| AGENT_EXTRACT

    %% ─── Maintenance loop ──────────────────────────────────────────────
    STATUS -.->|version or content-hash drift| REINIT["wh reinit<br/>Re-resolve changed deps<br/>Detect VERSION + CONTENT-HASH drift<br/>Write refresh-diff.json with<br/>re_extraction_candidates + extraction_prompt"]
    REINIT --> EXTRACT

    %% ─── CI path ───────────────────────────────────────────────────────
    CI_START([CI pipeline])
    CI_START --> CI["wh ci --fail-on stale<br/>Freshness gate<br/>Optional PR comment"]
    CI --> CHECK
    CI_START -.->|per-PR summary| REPORT

    %% ─── Deferred / future ─────────────────────────────────────────────
    DONE -.-> FUTURE["Deferred in 0.3.0 lean refactor:<br/>• wh bench / wh eval / wh patterns<br/>• wh propose / wh apply (→ extract submit + approve)<br/>• wh promote / wh layers (2-layer merge instead)<br/>• wh config show / validate (inspector deferred)<br/>• Team extends:, built-in rules layer<br/>• MCP server, shared rule registry (Epic 4)"]

    %% ─── Styling ───────────────────────────────────────────────────────
    classDef binary fill:#2d6a4f,color:#fff,stroke:#1b4332
    classDef agent fill:#e76f51,color:#fff,stroke:#c1440e
    classDef user fill:#264653,color:#fff,stroke:#f1faee
    classDef jit fill:#7952b3,color:#fff,stroke:#4c2a85
    classDef future fill:#7d8597,color:#fff,stroke:#5c677d
    classDef start fill:#f4a261,color:#000,stroke:#e76f51

    class INIT,EXTRACT,SUBMIT,APPROVE,VALIDATE,ACTIONS,CHECK,STATUS,REPORT,REINIT,CI binary
    class AGENT_EXTRACT,AGENT_EDIT,AGENT_FIX agent
    class USER user
    class SOURCE_ADD,SOURCE_OPS,AUTHOR_SHORT,RULE_EDIT,RULES_QUERY jit
    class FUTURE future
    class START,CI_START,DONE start
