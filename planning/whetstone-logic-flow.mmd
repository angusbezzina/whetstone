%%{ init: { "theme": "base", "themeVariables": { "fontSize": "14px" } } }%%
flowchart TD
    %% ═══════════════════════════════════════
    %% WHETSTONE — LOGIC FLOW (post Epic 3E, [Unreleased] → 0.4.0)
    %%
    %% Green  = Binary (shipped deterministic commands)
    %% Orange = Agent  (judgment via SKILL.md)
    %% Blue   = User   (approval / preference decisions)
    %% Purple = JIT side-channel + authoring shortcuts (Epic 3E)
    %% Grey   = Deferred / future
    %% ═══════════════════════════════════════

    START([User: run whetstone / extract rules]) --> INIT["wh init --json<br/>Detect manifests<br/>Resolve docs + changelogs<br/>Write extraction-handoff.json"]

    INIT --> EXTRACT["wh extract --json<br/>Walk worklist<br/>Ranked sources + quota<br/>Next dep to extract"]

    EXTRACT --> AGENT_EXTRACT["Agent reads extraction handoff<br/>Reads the top dep's docs<br/>Drafts a bundle YAML"]

    AGENT_EXTRACT --> SUBMIT["wh extract submit &lt;bundle.yaml&gt;<br/>Validate ids, write status: candidate<br/>whetstone/rules/&lt;lang&gt;/&lt;dep&gt;.yaml"]

    %% Authoring shortcut (Epic 3E) — skips extract/submit for personal prefs
    AUTHOR_SHORT["wh rule add &lt;id&gt;<br/>--description / --match / --lang<br/>Writes .personal/rules/ as APPROVED"]
    START -.->|personal taste| AUTHOR_SHORT
    AUTHOR_SHORT --> ACTIONS

    SUBMIT --> USER{"User reviews<br/>candidate set"}

    USER -->|wh approve --all| APPROVE["wh approve<br/>Flip candidate → approved<br/>Single id or batch filters"]
    USER -->|Edit bundle| AGENT_EDIT["Agent edits bundle"] --> SUBMIT
    USER -.->|mature taste: bump severity| RULE_EDIT["wh rule edit &lt;id&gt; --severity must<br/>or --all --dep X --severity must<br/>(--dry-run supported)"]
    RULE_EDIT --> APPROVE

    APPROVE --> VALIDATE["wh validate --json<br/>Schema + fixture checks"]
    VALIDATE -->|Fix issues| AGENT_FIX["Agent fixes YAML"] --> VALIDATE
    VALIDATE --> ACTIONS["wh actions [--terse]<br/>wh context → AGENTS.md + AGENTS.&lt;lang&gt;.md sidecars<br/>wh tests → evals/<br/>wh lint → lint/"]

    ACTIONS --> CHECK["wh check src/<br/>Tree-sitter AST queries<br/>AST-scoped regex checks<br/>lint_proxy config verification"]
    CHECK --> STATUS["wh status --json<br/>rule_system_score + adherence_score<br/>violation trend in .metrics.jsonl"]
    STATUS --> REPORT["wh report [--pr-comment]<br/>One-page markdown narrative<br/>Adherence + top 10 violations + next actions"]
    REPORT --> DONE([Done: rules enforced, agents informed, repo scored])

    %% JIT side-channel (Epic 3E) — agents prefer this over re-scanning AGENTS.md
    RULES_QUERY["wh rules query --file &lt;path&gt;<br/>Filters: --lang / --dep / --severity / --full<br/>JSON envelope: { total, filters, rules[] }"]
    AGENT_EXTRACT -.-> RULES_QUERY
    RULES_QUERY -.-> AGENT_EXTRACT

    %% Refresh loop — now carries per-rule candidates + canned prompt
    STATUS -.->|Dependency drift| REINIT["wh reinit --json<br/>Re-resolve changed sources<br/>Detect VERSION + CONTENT-HASH drift<br/>Write refresh-diff.json with<br/>re_extraction_candidates + extraction_prompt"]
    REINIT --> EXTRACT

    %% CI path
    CI_START([CI pipeline]) --> CI["wh ci --fail-on stale<br/>Freshness gate<br/>Optional PR comment"]
    CI --> CHECK
    CI_START -.->|per-PR summary| REPORT

    %% Deferred / future
    DONE -.-> FUTURE["Deferred in 0.3.0 lean refactor:<br/>• wh bench / wh eval / wh patterns<br/>• wh propose / wh apply (replaced by extract submit + approve)<br/>• wh promote / wh layers (merge collapsed to personal + project)<br/>• wh config show/validate<br/>• Team extends, built-in rules layer<br/>• MCP server, shared rule registry (Epic 4)"]

    %% Styling
    classDef binary fill:#2d6a4f,color:#fff,stroke:#1b4332
    classDef agent fill:#e76f51,color:#fff,stroke:#c1440e
    classDef user fill:#264653,color:#fff,stroke:#f1faee
    classDef jit fill:#7952b3,color:#fff,stroke:#4c2a85
    classDef future fill:#7d8597,color:#fff,stroke:#5c677d
    classDef start fill:#f4a261,color:#000,stroke:#e76f51

    class INIT,EXTRACT,SUBMIT,APPROVE,VALIDATE,ACTIONS,CHECK,STATUS,REPORT,REINIT,CI binary
    class AGENT_EXTRACT,AGENT_EDIT,AGENT_FIX agent
    class USER user
    class RULES_QUERY,AUTHOR_SHORT,RULE_EDIT jit
    class FUTURE future
    class START,CI_START start
